# Trau configuration template.
#
# Trau uses a layered config model. From lowest to highest precedence:
#
#   1. built-in defaults
#   2. local config file  ->  ./trau.ini (or TRAU_ENV) when no target repo is given
#   3. project config file -> <repo>/.trau.ini  (repo-specific facts)
#   4. user config file    -> ~/.trau.ini      (personal / machine overrides)
#   5. process environment variables — any KEY below, or its collision-safe
#      TRAU_<KEY> alias (e.g. TRAU_PROVIDER, TRAU_REMOTE) which wins over the
#      bare name and avoids clashing with a generic PROVIDER/REMOTE in your shell
#   6. CLI flags (--repo, --provider, etc.)
#
# Format: a flat INI subset (KEY=value with # comments). The keys ARE the
# environment-variable names, so PROVIDER here and TRAU_PROVIDER in your shell
# are the same knob. Saved with a .ini extension so VS Code and IntelliJ
# highlight it with no plugin.
#
# This file is the template / local fallback. For day-to-day work on a target
# project, copy the project-appropriate knobs into <repo>/.trau.ini and keep
# machine-trust flags (CLAUDE_FLAGS, CODEX_FLAGS, etc.) in ~/.trau.ini.
#
# Linear can be reached either through the Linear MCP inside agent calls OR
# directly via Linear's GraphQL API when LINEAR_API_KEY is set. The direct API
# is faster for common read/write operations; MCP is used for complex operations
# that require reasoning over files.

# =============================================================================
# PROJECT-LEVEL KNOBS (put these in <repo>/.trau.ini)
# =============================================================================
#
# The TUI first-run onboarding wizard can generate <repo>/.trau.ini for you.
# Run `trau` with no arguments inside a repo that has no .trau.ini to start it.

# --- project-management backend ---
TRACKER_PROVIDER=linear      # linear | jira | github | internal
                             # internal = trau's own issues in the hub (ADR 0007), no external tracker.
                             # A repo with no Linear/Jira/GitHub configured uses internal automatically.
LINEAR_TEAM=YourTeam         # your Linear team name, Jira project key, or GitHub repo slug (required for whole-team picks)
ISSUE_PREFIX=                # ticket-ID prefix for parsing, branch inference, and sentinels
                             # (e.g. COD, TMS, ENG). Empty = derive from the team key above; falls back to COD.
                             # Also names internally-created issues (LOOP-12); when unset, those default to
                             # the repo directory name, sanitized uppercase — never the team key
READY_LABEL=ready-for-agent
QUARANTINE_LABEL=needs-human
SPLIT_LABEL=needs-split      # label the pre-flight size judge applies to a ticket it flags as
                             # too large to build in one window (see SIZE_JUDGE under loop control)
PROJECT=                     # Linear project this repo owns (e.g. salonradar.com). When set, the loop only
                             # picks tickets in this project, refuses a run on a ticket from another project
                             # before any branch/checkpoint, and files bugs here. Empty = no project scoping.

# --- git / GitHub ---
BASE_BRANCH=main
REMOTE=origin
# Target app repo the loop operates on (REPO_ROOT). Usually empty in project
# config; the repo is resolved first from --repo, then TRAU_REPO_ROOT, then
# the cwd git top-level (ADR 0001 §2).
TRAU_REPO_ROOT=

# --- provider defaults for this project ---
# Which provider backs this loop: claude (default) | codex | kimi. Override per-run
# with --provider <name>.
PROVIDER=claude

# Execution tuning is two independent dials per provider: model (capability) and
# effort (reasoning depth / latency). Set a default model and effort for the active
# provider, then optionally override either per phase below. There are no bundled
# speed presets — "fast on a smart model" is just a strong model at low effort.
#
# Effort is provider-specific. Claude takes --effort (low|medium|high|xhigh|max);
# Codex takes -c model_reasoning_effort (minimal|low|medium|high|xhigh). Kimi Code has
# NO usable effort knob in headless runs (its KIMI_MODEL_THINKING_EFFORT only applies
# via the KIMI_MODEL_* env-provider), so KIMI_MODEL is a model dial only — and the
# value is a model ALIAS defined in your kimi config.toml [models.<alias>], not an ID.
#
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_EFFORT=medium
# CODEX_MODEL=gpt-5.5
# CODEX_EFFORT=medium
# KIMI_MODEL=kimi-for-coding

# Per-provider phase tuning for this project. Phases: BUILD HANDOFF VERIFY REPAIR
# BUGFIX CLEANUP LINTFIX SIZEJUDGE COMMIT PLAN SLICE PICK. Model/effort are provider-specific.
# PLAN and SLICE are the planning module's rounds; they are never seeded, so each stays
# on the provider default model unless you set CLAUDE_PLAN_MODEL / CODEX_PLAN_MODEL /
# KIMI_PLAN_MODEL (and the matching *_SLICE_MODEL keys).
#
# On Claude, the cheap judgment/cleanup phases are seeded so they don't ride the
# Opus default: CLEANUP, SIZEJUDGE, COMMIT, and HANDOFF -> sonnet, LINTFIX -> haiku
# (a phase left unset otherwise inherits Default); BUILD, VERIFY, REPAIR, and BUGFIX
# keep the Opus default. Only the model is seeded — effort still inherits the default,
# so set e.g. CLAUDE_COMMIT_EFFORT=low to trim the commit phase further. These are
# independent of PICK, so downtiering cleanup no longer also downtiers
# epic-sync/epic-repair. Set the dedicated keys to override a seed; if you previously
# relied on CLAUDE_PICK_MODEL covering cleanup/lintfix, set these.
#
# Example Claude tuning: Opus for implementation, Sonnet for cold verify.
# CLAUDE_BUILD_MODEL=claude-opus-4-8
# CLAUDE_BUILD_EFFORT=max
# CLAUDE_VERIFY_MODEL=claude-sonnet-4-6
# CLAUDE_VERIFY_EFFORT=medium
# CLAUDE_BUGFIX_MODEL=claude-opus-4-8
# CLAUDE_BUGFIX_EFFORT=max
# CLAUDE_CLEANUP_MODEL=claude-sonnet-4-6
# CLAUDE_SIZEJUDGE_MODEL=claude-sonnet-4-6
# CLAUDE_COMMIT_MODEL=claude-sonnet-4-6
# CLAUDE_COMMIT_EFFORT=low
# CLAUDE_HANDOFF_MODEL=claude-sonnet-4-6
#
# Example Codex tuning: hardest work on GPT-5.5, mechanical phases on lighter Codex.
# CODEX_BUILD_MODEL=gpt-5.5
# CODEX_BUILD_EFFORT=xhigh
# CODEX_REPAIR_MODEL=gpt-5.5
# CODEX_REPAIR_EFFORT=high
# CODEX_BUGFIX_MODEL=gpt-5.5
# CODEX_BUGFIX_EFFORT=xhigh
# CODEX_VERIFY_MODEL=gpt-5.5
# CODEX_VERIFY_EFFORT=medium
# CODEX_COMMIT_MODEL=gpt-5.4-mini
# CODEX_COMMIT_EFFORT=low
# CODEX_PICK_MODEL=gpt-5.4-mini
# CODEX_PICK_EFFORT=low
#
# Example Kimi tuning: a different config.toml model alias per phase (no effort knob).
# KIMI_BUILD_MODEL=kimi-for-coding
# KIMI_COMMIT_MODEL=kimi-fast

# --- loop control ---
MAX_ITERATIONS=15
MAX_REPAIRS=2                # quick verify-fail self-heal attempts before bugfix (0 = none)
MAX_BUGFIXES=2               # comprehensive bugfix passes after quick repairs (0 = none)
MAX_PLAN_ROUNDS=3            # rounds of clarifying questions a plan may ask before the PRD is forced
AUTO_MERGE=1                 # 1 = merge on green CI; 0 = stop at the PR for you
EPIC_FLOW=1                  # 1 = run sub-issues on an epic branch, then close the parent and open the
                             #     epic-to-BASE_BRANCH PR only after every direct child is closed
                             # 0 = always process the passed ticket as a standalone branch from BASE_BRANCH
MERGE_METHOD=squash          # squash | merge | rebase
DETERMINISTIC_COMMIT=1        # 1 = for squash repos, stage and commit the slice deterministically
                             #     (templated Conventional Commit with a Refs trailer, no commit agent)
                             #     since the squash collapses the message anyway — saves one agent spawn
                             #     per ticket. 0 restores the agent commit where commit conventions need
                             #     judgment. Non-squash methods always use the agent commit.
CI_TIMEOUT=600               # seconds to wait for required checks to appear AND finish
CI_POLL=30                   # seconds between check polls
EXPECTED_CHECKS=             # named checks (substring, case-insensitive) that must be PRESENT
                             # and green before merge. EMPTY = wait for whatever PR checks exist
                             # with none pending. Empty is right when your repo's tests run
                             # locally (the loop's verify phase is the gate); set to e.g.
                             # "tests,lint" when those checks run on the PR itself.
REQUIRE_CI=1                 # 1 = gate merge on CI checks. Set 0 when the repo has NO PR-triggered
                             # CI (e.g. only a deploy-on-push workflow): the PR then has zero checks,
                             # which would otherwise spin to CI_TIMEOUT and quarantine. With 0 the
                             # gate is skipped and the loop merges/leaves the clean PR per AUTO_MERGE.
REQUIRE_REPO_CHANGES=1       # 1 = after build, fault when the managed repo is unchanged (clean tree
                             # AND no new commits vs base) instead of advancing to a hollow handoff /
                             # empty PR — catches an agent that built in the wrong repo or escaped its
                             # cwd. The ticket is left resumable. Set 0 for a legitimately no-op ticket.
SIZE_JUDGE=1                 # 1 = before building a fresh ticket, a cheap LLM judge sizes it; one too
                             # large to finish in a single build window is quarantined + labeled
                             # SPLIT_LABEL with the suggested seams (autonomous / headless run), or
                             # warned about but built anyway (attended single-ticket run). 0 disables it.

# --- budget governance ---
# Spend ceilings enforced off the normalized token/cost ledger. Empty = no cap
# (default; fully back-compatible). Checked against the live tokens.jsonl totals
# before each agent call: a ticket that reaches its per-ticket cap is quarantined
# (ready-for-agent dropped, needs-human added) with a cost-overrun note and the loop
# moves on; reaching a per-day cap (summed across ALL tickets that day) stops the run
# cleanly so it can resume tomorrow or once you raise the cap. Set USD caps, token
# caps, or both — the USD figure is the same notional estimate shown by --status, so
# on unmetered providers (kimi) prefer the token caps. See the COST NOTE at the
# bottom of this file.
MAX_TICKET_USD=              # e.g. 5      → quarantine a ticket once its est. cost reaches $5
MAX_TICKET_TOKENS=           # e.g. 2000000 → quarantine a ticket once it reaches 2M tokens
MAX_DAILY_USD=               # e.g. 50     → stop the run once today's spend reaches $50
MAX_DAILY_TOKENS=            # e.g. 50000000 → stop the run once today reaches 50M tokens

# --- TUI ---
# Enable the Bubble Tea TUI when running in a terminal. Set to 0 to force the
# original plain log output. This is also toggled per-run with --no-tui.
# Pipes, cron, TRAU_LOG_JSON=1, and --status always use plain output.
TRAU_TUI=1

# Color theme. The palette adapts to the terminal's light/dark background
# automatically; a preset swaps the whole palette. Unknown names fall back to
# default with a note. Presets: default | catppuccin | dracula | gruvbox | nord.
#THEME=default
# Individual semantic colors can be overridden with hex values via
# THEME_<ROLE>, where ROLE is one of BRAND, ACCENT, SUCCESS, ERROR, WARNING,
# INFO, TEXT, SUBTLE, FAINT, SURFACE, BORDER, INK.
#THEME_BRAND=#00D4AA

# Usage HUD provider window. When 1, the HUD bar tracks the active provider's real
# rate-limit window (claude OAuth usage, codex app-server, kimi prepaid balance).
# Every probe is metadata-only and fails closed to token/cost totals, so it is safe
# to leave on; set 0 to skip provider polling entirely.
USAGE_WINDOW=1
# Pseudo-terminal /usage fallback. Off by default. When 1, providers with no
# structured window (notably Kimi-Code *subscription* users) are probed by driving
# their CLI's /usage panel in a pty and scraping it — brittle and version-sensitive,
# so opt-in only.
USAGE_WINDOW_PTY=0

# --- verify ---
LINT_FIX=1                   # 1 = just before verify, run the project's automated lint/format fixers over
                             # the working tree so verify isn't spent self-healing mechanical style noise
                             # (whatever can't be auto-fixed still falls through to verify). 0 disables it.
LINT_FIX_CMD=                # deterministic fixer command run in the target repo before verify, e.g.
                             # vendor/bin/pint or "npm run lint:fix" — zero tokens, exit code ignored
                             # (fails open). Empty = a cheap agent auto-detects and runs the project's fixers.
CLEANUP=1                    # 1 = just before verify, a cheap agent strips AI-slop from the slice's diff —
                             # unnecessary comments, dead code, over-defensive scaffolding — so the code reads
                             # hand-written. Behavior-preserving; fails open. 0 disables it.
BROWSER_VERIFY=auto          # auto (browser only for UI slices) | always | never
APP_URL=http://localhost     # base URL of your locally-running app (used by browser verify)
# Run the pluggable verify-check library each verify phase. Checks live in the
# TARGET repo under .trau/checks/*.yaml (name, severity, command|prompt, tools);
# severity gates the merge (error blocks, warn only surfaces). With no custom
# checks, a built-in default set runs (tests, typecheck, lint, anti-placeholder,
# anti-duplication). Set 0 to disable entirely. See docs/verify-checks.md.
VERIFY_CHECKS=1
# Cross-vendor verify panel (the moat): run verify as N fresh, isolated processes
# from DIFFERENT providers, each independently judging the diff, then merge their
# verdicts. Each member is a provider:model:effort spec (model/effort optional);
# empty = single verifier (default). Policy: unanimous (any dissent blocks) |
# majority | any-pass. See docs/verify-panel.md.
# VERIFY_PANEL=claude,codex:gpt-5.5,kimi
VERIFY_PANEL_POLICY=unanimous

# --- lessons memory ---
# Durable lessons memory: each repair experiment (failure type, attempted fix,
# evidence, result, distilled lesson) is appended to runs/memory/lessons.jsonl
# after a repaired success or a quarantine, and the lessons relevant to a slice
# are recalled into later build/verify/repair prompts so failed runs teach future
# runs. Relevance is filtered and capped, so an empty/thin ledger injects nothing.
# 1 = on (default), 0 = off (no recording, no recall).
LESSONS=1
# Enrich each recorded lesson with a cheap, isolated agent pass that distills a
# richer, ticket-agnostic takeaway. Off by default: the free mechanical record
# (synthesized from the verdict) is always written when LESSONS=1, and this only
# changes how the lesson TEXT is produced — at the cost of one extra agent call on
# each failure-path ticket. 1 = agent-distilled, 0 = mechanical only (default).
LESSONS_DISTILL=0
# The ledger lives under runs/ (gitignored) so it is run-scoped/local by default.
# See docs/lessons-memory.md for the record schema and when to commit a curated
# digest vs keep it local.

# --- time tracking (opt-in, OFF by default) ---
# Optional per-ticket time tracking. When enabled, trau writes a per-ticket
# human-EFFORT estimate after a ticket merges to
# <repo>/.trau/time/<TICKET>.json, as JSON that other time-tracking tools can
# read (the schema stays dev-flow-compatible; logs from the old .dev-flow/time/
# location are migrated automatically on the next write). This is OFF by
# default: with TIMELOG_ENABLED=0 (or unset) NONE of this runs and trau behaves
# exactly as before — no time-log writes, no estimation, zero overhead. The
# first-run onboarding wizard offers a toggle (defaulting to off). The number is
# an ESTIMATE of senior-developer effort, never agent wall-clock.
TIMELOG_ENABLED=0            # 1 = write the per-ticket effort log after merge; 0 = off (default)
TIMELOG_STORAGE=repo         # repo  -> <repo>/.trau/time/<TICKET>.json (default; per-repo, where tools read)
                             # user  -> ~/.trau/time/<repo-slug>/<TICKET>.json
                             # none  -> persist nothing
TIMELOG_OUTPUT_FORMAT=default # export rendering: default (canonical JSON) | jira-worklog | toggl-csv | plain.
                             # The persisted file is always JSON; a non-default value also writes a
                             # copy-paste sibling export next to it.
TIMELOG_ESTIMATOR=heuristic  # heuristic = deterministic diffstat/file/commit -> minutes table (default,
                             #             no extra agent cost); agent = a cheap agent call estimates minutes
# With TIMELOG_STORAGE=repo, trau adds `.trau/time/` to the target repo's
# .gitignore if absent (effort numbers are per-developer / sensitive); it never
# blanket-ignores .trau/ (a project's .trau/checks/ verify library is meant to be committed).

# =============================================================================
# USER / MACHINE KNOBS (put these in ~/.trau.ini)
# =============================================================================
# These are personal or machine-trust settings. They should generally NOT be
# committed to a project repo, especially the permission-override flags.

# Provider binaries and dangerous permission overrides. Use only in trusted,
# sandboxed checkouts — these disable approval prompts.
CLAUDE_BIN=claude
CLAUDE_FLAGS=--dangerously-skip-permissions
# Tools blocked inside every phase. Agent (subagent spawning) and Workflow (multi-
# agent fan-out) are off by default: each phase already runs as its own isolated
# process, so fan-out only multiplies token cost. Resolve per phase like the model
# keys — CLAUDE_<PHASE>_DISALLOWED_TOOLS overrides this default for one phase
# (e.g. CLAUDE_BUILD_DISALLOWED_TOOLS=Workflow).
CLAUDE_DISALLOWED_TOOLS=Agent,Workflow

# Opt the build and verify phases into read-only exploration subagents (Claude's
# Explore agent type): those phases drop Agent from their disallowed set so the
# orchestrator can fan investigation out and keep its own context lean on large
# tickets, while write-capable fan-out (Workflow) stays blocked in every phase. Off
# by default; an explicit CLAUDE_<PHASE>_DISALLOWED_TOOLS still wins per phase.
# EXPLORE_SUBAGENTS=0

CODEX_BIN=codex
CODEX_FLAGS=--dangerously-bypass-approvals-and-sandbox
CODEX_PROFILE=

# Linear personal API key. Enables fast direct GraphQL calls for title lookups,
# status moves, label changes, etc. Create one in Linear under
# Settings > Account > Security & Access > API. Keep this in ~/.trau.ini, NOT
# in a committed project config file.
LINEAR_API_KEY=

# Jira Cloud direct REST access (TRACKER_PROVIDER=jira). When JIRA_API_TOKEN is
# set, trau reaches Jira directly over the REST v3 API for fast read/write ops and
# falls back to the Jira (Rovo) MCP only when it is empty or the token is rejected.
# Because auth is per-request Basic auth (no shared OAuth session), two repos tied
# to two SEPARATE Jira accounts each keep their own credentials in their own
# .trau.ini — the direct fix for the multi-account limit of the single-identity MCP.
# Use a CLASSIC (unscoped) token from id.atlassian.com/manage-profile/security/api-tokens
# so the simple <site>.atlassian.net base URL works. Treat the token like
# LINEAR_API_KEY: keep it in ~/.trau.ini or a per-repo .trau.ini, never committed.
# The Jira project key reuses LINEAR_TEAM above.
JIRA_BASE_URL=               # e.g. https://acme.atlassian.net
JIRA_EMAIL=                  # your Atlassian account email
JIRA_API_TOKEN=              # classic API token (never commit)
#
# TWO SEPARATE JIRA ACCOUNTS — the reason this adapter exists. Give each repo its
# own .trau.ini with its own account (the onboarding wizard writes these for you
# and gitignores the file), so one account never leaks into the other repo:
#
#   # ~/work/acme-app/.trau.ini
#   TRACKER_PROVIDER=jira
#   LINEAR_TEAM=ACME
#   JIRA_BASE_URL=https://acme.atlassian.net
#   JIRA_EMAIL=you@acme.com
#   JIRA_API_TOKEN=<acme classic token>
#
#   # ~/work/widgets/.trau.ini
#   TRACKER_PROVIDER=jira
#   LINEAR_TEAM=WID
#   JIRA_BASE_URL=https://widgets.atlassian.net
#   JIRA_EMAIL=you@widgets.com
#   JIRA_API_TOKEN=<widgets classic token>
#
# Classic tokens can't self-refresh and expire ~annually; on a 401 trau prints a
# "regenerate at id.atlassian.com/manage-profile/security/api-tokens" hint. Run
# `trau doctor` to validate the three keys and live-ping the site before a run.

KIMI_BIN=kimi
KIMI_FLAGS=

# Optional provider-local KEY=value files, resolved relative to the env file that
# names them. Leave empty if unused.
CLAUDE_CONFIG=
CODEX_CONFIG=
KIMI_CONFIG=

# Per-agent call HARD timeout in seconds. Interactive Claude writes a PTY transcript
# next to the expected result file when this trips, so failures have evidence.
AGENT_TIMEOUT=900

# Geometry of the interactive agent PTY (Claude), bumped past the 80x24 fallback so
# wide diffs and tool output aren't wrapped at 80 columns. Under the TUI dashboard
# the agent is auto-sized to the live pane; these values apply to headless runs and
# are what `trau watch` reconstructs. Set both to 80/24 for parity.
AGENT_COLS=120
AGENT_ROWS=40

# Launch the mechanical phases — cleanup, commit, repair, bugfix, push-repair — with
# the target repo's MCP servers stripped, where the provider CLI supports it (Claude's
# --strict-mcp-config). Those phases never read the tracker, so the MCP server schemas
# only cost startup latency and context tokens; build, handoff, and verify keep the
# full MCP config (they fall back to MCP ticket reads). Providers with no strip
# mechanism run unchanged. Set 0 to restore full MCP everywhere if a repo's hooks or
# tests depend on MCP tooling in those phases.
STRIP_MECHANICAL_MCP=1

# --- transient-failure recovery (COD-583) ---
# A transient agent-step failure — a stalled subprocess, a hard timeout, or a
# non-rate-limit crash — self-heals instead of parking the ticket: the step is
# retried on a fresh process, then handed to the next fallback provider, and only
# when the whole chain is exhausted does the run stop (with the WIP preserved on
# its branch and the ticket left resumable). Rate-limits still pause (blameless)
# and verified give-ups still quarantine — both unchanged.
#
# Kill+recover a step that emits NO transcript output for this many seconds, well
# before AGENT_TIMEOUT (Claude interactive only; 0 = disabled, wait the full
# AGENT_TIMEOUT). Catches a subprocess that stalls before it ever starts working.
AGENT_STALL_WINDOW=180
# Transient retries on the SAME provider before falling back / parking.
AGENT_RETRIES=2
# Base seconds to wait between transient retries (grows with the attempt number).
AGENT_BACKOFF=10
# Ordered provider[:model[:effort]] specs to try after the primary provider's
# retries are exhausted, for ANY phase. Reuses the route spec format. Empty =
# retry-only (no provider fallback). Example: codex,kimi
# FALLBACK_PROVIDERS=codex,kimi

# Optional provider model/effort defaults when a phase does not override them.
# Empty = provider or profile default.
CLAUDE_MODEL=
CLAUDE_EFFORT=
CODEX_MODEL=
CODEX_EFFORT=
KIMI_MODEL=

# --- artifacts ---
# Root for per-ticket run artifacts: runs/<ID>/{state,*.log,tokens.jsonl}. Defaults
# to ./runs (relative to the working directory). Point it at a stable path if you
# run the loop from varying directories.
RUNS_DIR=runs

# --- serve (trau serve HTTP hub) ---
# `trau serve` starts a local HTTP server: a versioned JSON API under /api/v1
# and an embedded web UI at /. The hub controls an autonomous, merge-capable
# system, so exposing it is a safety decision, not a convenience toggle.
#
# The default bind is loopback-only and needs no token. Any non-loopback bind
# (e.g. SERVE_BIND=0.0.0.0) REQUIRES a bearer token: trau refuses to start
# exposed without SERVE_TOKEN, and every API request must then send
# `Authorization: Bearer <token>` or gets a 401. The blessed remote path is a
# private network — put the host on Tailscale and reach it over the tailnet
# rather than opening a port to the public internet.
SERVE_BIND=127.0.0.1
SERVE_PORT=8728
SERVE_TOKEN=                  # required once SERVE_BIND leaves loopback; a long random secret (never commit)
#
# Registering or unregistering a repo over the API is fail-closed on an exposed
# bind: it needs SERVE_ALLOW_REGISTER=1 on top of the token, so a leaked token
# cannot widen the hub's startable-repo set. Loopback binds ignore it and stay
# open. Default off.
SERVE_ALLOW_REGISTER=0
#
# The hub may only START loops in repos on this allowlist. Everything else it
# discovers through the registry is observe-only. Empty (the default) means the
# hub starts nothing; stopping an already-running loop works regardless.
# SERVE_WORKSPACE=/Users/me/Projects/salonradar,/Users/me/Projects/loop
#
# The hub refreshes each repo's local issue store from its tracker in the
# background on this cadence (incremental pulls off the stored cursor, so an edit
# in the tracker shows up within one interval, hands-off). A repo with a broken
# tracker config backs off on its own without stalling the others. Set 0 to
# disable it and rely on on-demand pulls only.
SERVE_SYNC_INTERVAL=120        # seconds between background issue-store refreshes
#
# The first interactive TUI session brings the hub up on its own (one per
# machine) so the web UI is there whenever you work with trau; it reuses any hub
# already on the port and inherits the SERVE_* settings above, so an autostarted
# hub is identical to one you start by hand. It persists until reboot or an
# explicit stop. Set 0 to never autostart (start it yourself with `trau serve`);
# `--no-serve` disables it for one run.
SERVE_AUTOSTART=1
#
# When autostart freshly spawns the hub it also opens the browser (health-gated,
# best-effort — skipped over SSH or without a display). Set 0 to keep the daemon
# but not launch a browser; the TUI still prints the Web UI URL.
SERVE_OPEN=1

# COST NOTE: the "~$X est" in the closing recap (and --status) is a NOTIONAL
# API-list estimate, not a bill — no provider cost is reported for interactive
# Claude runs, so trau prices tokens itself. Most of the token TOTAL is
# cache-read tokens, billed at 0.1× input (5-min cache writes at 1.25×), so a
# multi-million-"token" phase is mostly cheap cache hits, not fresh spend. On a
# Claude subscription your marginal cost is the flat plan fee (~$0 per run); the
# estimate is useful as a *relative* signal between phases/models, not a charge.
