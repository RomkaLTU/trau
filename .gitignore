# Local config (copy from trau.ini.example; .trau.ini for project/user scope)
trau.ini
.trau.ini

# Agentic / internal files — kept out of the public repo (present locally)
tasks/
runs/
/.agents/
/.claude/
/.serena/
/AGENTS.md
/CLAUDE.md
/CONTEXT.md

# Per-developer dev-flow config (bind it to your own tracker/team locally)
/.dev-flow/

# Go build artifacts
/trau
/bin/
/dist/
*.test
*.out
coverage.txt

# SPA toolchain (web/ is the Vite source; internal/webserver/dist is the
# embedded build output and IS tracked so `go build`/`go test` always compile)
/web/node_modules/
/web/.vite/
# npm is canonical here (web/package-lock.json is tracked); ignore stray pnpm locks
/web/pnpm-lock.yaml

# IDE
/.idea/
# trau run artifacts and project config (do not commit)
.trau/runs/
